# Local development shop for the WebMCP plugin (Dockware).
#
#   cp .env.example .env      # then edit any ports that clash on your machine
#
# docker compose and bin/shop.sh read this file automatically.

# Shopware version = Dockware image tag.
# Must satisfy composer.json ("shopware/core >=6.6.10.18 <6.8.0").
# The 6.6.x Dockware line only goes up to 6.6.10.6, so use a 6.7.x tag.
SW_VERSION=6.7.2.2

# Host ports. Change any that are already taken on your machine.
SHOP_HTTP_PORT=8000              # Storefront + Admin -> http://localhost:8000  (/admin: admin / shopware)
                                 # Adminer (DB UI)    -> http://localhost:8000/adminer.php
SHOP_DB_PORT=3306                # MySQL              -> localhost:3306 (root / root, db: shopware)
SHOP_MAIL_PORT=1080              # MailCatcher web UI -> http://localhost:1080

# Watcher ports (only needed for hot-reload dev; safe to leave as-is).
SHOP_STOREFRONT_WATCH_PORT=9998
SHOP_STOREFRONT_HOT_PORT=9999
SHOP_VITE_PORT=5173
