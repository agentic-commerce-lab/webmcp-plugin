{
    "name": "shopware/web-mcp",
    "description": "Shopware plugin exposing storefront WebMCP tools via document.modelContext",
    "version": "0.1.0",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Shopware AG",
            "homepage": "https://www.shopware.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "shopware/core": ">=6.6.10.18 <6.8.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Swag\\WebMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Swag\\WebMcp\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "php bin/lint",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "qa": [
            "@lint",
            "@phpstan",
            "@cs-check",
            "@test"
        ],
        "ci": "@qa"
    },
    "extra": {
        "shopware-plugin-class": "Swag\\WebMcp\\SwagWebMcp",
        "label": {
            "de-DE": "WebMCP",
            "en-GB": "WebMCP"
        },
        "description": {
            "de-DE": "Stellt Shopware-Storefront-Funktionen für KI-Agenten als WebMCP-Tools über document.modelContext bereit: Produktsuche, Produkt-/Kategorieabruf und serverseitige Warenkorbverwaltung.",
            "en-GB": "Exposes Shopware storefront capabilities to AI agents as WebMCP tools via document.modelContext: product search, product and category lookup, plus server-side cart management."
        },
        "manufacturerLink": {
            "de-DE": "https://github.com/agentic-commerce-lab/webmcp-plugin",
            "en-GB": "https://github.com/agentic-commerce-lab/webmcp-plugin"
        },
        "supportLink": {
            "de-DE": "https://github.com/agentic-commerce-lab/webmcp-plugin/issues",
            "en-GB": "https://github.com/agentic-commerce-lab/webmcp-plugin/issues"
        }
    },
    "config": {
        "sort-packages": true,
        "vendor-dir": ".tools/vendor",
        "allow-plugins": {
            "symfony/runtime": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": false
        },
        "platform": {
            "php": "8.2.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
