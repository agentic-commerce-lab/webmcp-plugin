{
    "name": "shopware/web-mcp",
    "description": "Shopware plugin for WebMCP side-car documents",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "shopware/core": ">=6.6.10.18 <6.8.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Swag\\WebMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Swag\\WebMcp\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "php bin/lint",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "qa": [
            "@lint",
            "@phpstan",
            "@cs-check",
            "@test"
        ],
        "ci": "@qa"
    },
    "extra": {
        "shopware-plugin-class": "Swag\\WebMcp\\SwagWebMcp",
        "label": {
            "de-DE": "WebMCP",
            "en-GB": "WebMCP"
        },
        "description": {
            "de-DE": "WebMCP Side-Car-Dokumente fuer Shopware",
            "en-GB": "WebMCP side-car documents for Shopware"
        }
    },
    "config": {
        "sort-packages": true,
        "vendor-dir": ".tools/vendor",
        "allow-plugins": {
            "symfony/runtime": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": false
        },
        "platform": {
            "php": "8.2.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
