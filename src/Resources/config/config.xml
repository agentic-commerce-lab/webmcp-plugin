<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>WebMCP</title>
        <title lang="de-DE">WebMCP</title>

        <input-field type="bool">
            <name>enabled</name>
            <label>Enable WebMCP endpoints</label>
            <label lang="de-DE">WebMCP-Endpunkte aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>context</name>
            <label>WebMCP context</label>
            <label lang="de-DE">WebMCP-Kontext</label>
            <defaultValue>Shopware storefront interaction graph</defaultValue>
        </input-field>

        <input-field type="textarea">
            <name>staticElementsJson</name>
            <label>Static elements JSON</label>
            <label lang="de-DE">Statische Elemente als JSON</label>
        </input-field>

        <input-field type="bool">
            <name>searchProductsToolEnabled</name>
            <label>Enable product search modelContext tool</label>
            <label lang="de-DE">Produktsuche-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getProductToolEnabled</name>
            <label>Enable get product modelContext tool</label>
            <label lang="de-DE">Produktdetails-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getProductCategoriesToolEnabled</name>
            <label>Enable product categories modelContext tool</label>
            <label lang="de-DE">Produktkategorien-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getCartToolEnabled</name>
            <label>Enable get cart modelContext tool</label>
            <label lang="de-DE">Warenkorb-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>addToCartToolEnabled</name>
            <label>Enable add to cart modelContext tool</label>
            <label lang="de-DE">In-den-Warenkorb-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>removeFromCartToolEnabled</name>
            <label>Enable remove from cart modelContext tool</label>
            <label lang="de-DE">Aus-dem-Warenkorb-modelContext-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>
</config>
