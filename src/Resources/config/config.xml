<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>WebMCP</title>
        <title lang="de-DE">WebMCP</title>

        <input-field type="bool">
            <name>enabled</name>
            <label>Enable WebMCP endpoints</label>
            <label lang="de-DE">WebMCP-Endpunkte aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>context</name>
            <label>WebMCP context</label>
            <label lang="de-DE">WebMCP-Kontext</label>
            <defaultValue>Shopware storefront interaction graph</defaultValue>
        </input-field>

        <input-field type="textarea">
            <name>staticElementsJson</name>
            <label>Static elements JSON</label>
            <label lang="de-DE">Statische Elemente als JSON</label>
        </input-field>

        <input-field type="bool">
            <name>searchProductsToolEnabled</name>
            <label>Enable search_products tool</label>
            <label lang="de-DE">search_products-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getProductToolEnabled</name>
            <label>Enable get_product tool</label>
            <label lang="de-DE">get_product-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getProductCategoriesToolEnabled</name>
            <label>Enable get_product_categories tool</label>
            <label lang="de-DE">get_product_categories-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>getCartToolEnabled</name>
            <label>Enable get_cart tool</label>
            <label lang="de-DE">get_cart-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>addToCartToolEnabled</name>
            <label>Enable add_to_cart tool</label>
            <label lang="de-DE">add_to_cart-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>updateLineItemToolEnabled</name>
            <label>Enable update_line_item tool</label>
            <label lang="de-DE">update_line_item-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>removeFromCartToolEnabled</name>
            <label>Enable remove_from_cart tool</label>
            <label lang="de-DE">remove_from_cart-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>navigateToolEnabled</name>
            <label>Enable navigate tool</label>
            <label lang="de-DE">navigate-Tool aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>
</config>
