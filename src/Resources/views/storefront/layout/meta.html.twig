{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% block layout_head_javascript_hmr_mode %}
    {% set webMcpEnabled = config('SwagWebMcp.config.enabled') %}
    {% set searchProductsToolEnabled = config('SwagWebMcp.config.searchProductsToolEnabled') %}
    {% set getProductToolEnabled = config('SwagWebMcp.config.getProductToolEnabled') %}
    {% set getProductCategoriesToolEnabled = config('SwagWebMcp.config.getProductCategoriesToolEnabled') %}
    {% set getCartToolEnabled = config('SwagWebMcp.config.getCartToolEnabled') %}
    {% set addToCartToolEnabled = config('SwagWebMcp.config.addToCartToolEnabled') %}
    {% set updateLineItemToolEnabled = config('SwagWebMcp.config.updateLineItemToolEnabled') %}
    {% set getSalesChannelContextToolEnabled = config('SwagWebMcp.config.getSalesChannelContextToolEnabled') %}
    {% set navigateToolEnabled = config('SwagWebMcp.config.navigateToolEnabled') %}
    {% set activeCategoryId = null %}
    {% if page.category is defined and page.category %}
        {% set activeCategoryId = page.category.id %}
    {% elseif page.navigationId is defined and page.navigationId %}
        {% set activeCategoryId = page.navigationId %}
    {% endif %}
    {% set currentProductId = null %}
    {% if page.product is defined and page.product %}
        {% set currentProductId = page.product.id %}
    {% endif %}
    {% set webMcpModelContextOptions = {
        enabled: webMcpEnabled,
        storeApiAccessKey: context.salesChannel.accessKey|default(null),
        navigationCategoryId: context.salesChannel.navigationCategoryId|default(null),
        activeCategoryId: activeCategoryId,
        currentProductId: currentProductId,
        tools: {
            searchProducts: searchProductsToolEnabled,
            getProduct: getProductToolEnabled,
            getProductCategories: getProductCategoriesToolEnabled,
            getCart: getCartToolEnabled,
            addToCart: addToCartToolEnabled,
            updateLineItem: updateLineItemToolEnabled,
            getSalesChannelContext: getSalesChannelContextToolEnabled,
            navigate: navigateToolEnabled
        }
    } %}

    <script
        id="swag-web-mcp-config"
        type="application/json"
        data-swag-web-mcp-model-context
        data-swag-web-mcp-model-context-options="{{ webMcpModelContextOptions|json_encode|escape('html_attr') }}"
    ></script>
    {{ parent() }}
{% endblock %}
