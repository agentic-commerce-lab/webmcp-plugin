{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% block layout_head_javascript_hmr_mode %}
    {% set webMcpModelContextOptions = {
        enabled: config('SwagWebMcp.config.enabled') is same as(false) ? false : true,
        context: config('SwagWebMcp.config.context') ?: 'Shopware storefront interaction graph',
        storeApiAccessKey: context.salesChannel.accessKey|default(null),
        staticElementsJson: config('SwagWebMcp.config.staticElementsJson'),
        tools: {
            searchProducts: config('SwagWebMcp.config.searchProductsToolEnabled') is same as(false) ? false : true,
            getProduct: config('SwagWebMcp.config.getProductToolEnabled') is same as(false) ? false : true,
            getProductCategories: config('SwagWebMcp.config.getProductCategoriesToolEnabled') is same as(false) ? false : true
        }
    } %}

    <script
        id="swag-web-mcp-config"
        type="application/json"
        data-swag-web-mcp-model-context
        data-swag-web-mcp-model-context-options="{{ webMcpModelContextOptions|json_encode|escape('html_attr') }}"
    ></script>
    {{ parent() }}
    <script type="module" src="{{ asset('bundles/swagwebmcp/webmcp-model-context.js') }}"></script>
{% endblock %}
